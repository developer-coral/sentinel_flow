# Core
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=sentinel_n8n
GENERIC_TIMEZONE=UTC
N8N_ENCRYPTION_KEY=replace_with_32_plus_random_characters

# AI provider: openrouter or anthropic
AI_PROVIDER=openrouter
AI_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_API_KEY=sk-or-v1-replace_me
ANTHROPIC_API_KEY=sk-ant-replace_me
REQUIRE_REAL_AI=true


# n8n credentials are configured in n8n UI for production-safe storage.
# Create SMTP credentials in n8n using Ethereal/SendGrid sandbox.
# Create HubSpot private app token credentials if CRM write demo is needed.

RESEND_API_KEY=replace_with_resend_api_key
HUBSPOT_API_KEY=replace_with_hubspot_private_app_token